{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aidn://contracts/cli-output/runtime-shared-coordination-doctor.v1",
  "title": "aidn runtime shared-coordination-doctor --json",
  "type": "object",
  "x-aidn-command": "aidn runtime shared-coordination-doctor --json",
  "x-aidn-contract-version": "cli-output-v1",
  "required": [
    "target_root",
    "ok",
    "status",
    "workspace",
    "source_of_truth",
    "metadata",
    "shared_coordination_backend",
    "findings",
    "recommended_actions",
    "operations"
  ],
  "properties": {
    "target_root": { "type": "string" },
    "ok": { "type": "boolean" },
    "status": { "type": "string" },
    "workspace": { "type": "object", "additionalProperties": true },
    "source_of_truth": { "type": "object", "additionalProperties": true },
    "metadata": { "type": "object", "additionalProperties": true },
    "shared_coordination_backend": { "type": "object", "additionalProperties": true },
    "shared_coordination_alignment": { "type": "object", "additionalProperties": true },
    "health": { "type": ["object", "null"], "additionalProperties": true },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "code", "message"],
        "properties": {
          "severity": { "type": "string" },
          "code": { "type": "string" },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "recommended_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "operations": {
      "type": "object",
      "required": [
        "local_first",
        "scope",
        "backend_kind",
        "backend_status",
        "schema_status",
        "source_of_truth_status",
        "metadata_status",
        "connection_secret_exposed",
        "doctor_status",
        "backup_command",
        "recommended_actions"
      ],
      "properties": {
        "local_first": { "type": "boolean" },
        "scope": { "type": "string" },
        "backend_kind": { "type": "string" },
        "backend_status": { "type": "string" },
        "schema_status": { "type": "string" },
        "source_of_truth_status": { "type": "string" },
        "metadata_status": { "type": "string" },
        "compatibility_status": { "type": "string" },
        "alignment_status": { "type": "string" },
        "connection_ref": { "type": "string" },
        "connection_secret_exposed": { "type": "boolean" },
        "doctor_status": { "type": "string" },
        "finding_count": { "type": "number" },
        "backup_command": { "type": "string" },
        "recommended_actions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
