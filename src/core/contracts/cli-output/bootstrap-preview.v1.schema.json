{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aidn://contracts/cli-output/bootstrap-preview.v1",
  "title": "aidn bootstrap --dry-run --json",
  "type": "object",
  "x-aidn-command": "aidn bootstrap --dry-run --json",
  "x-aidn-contract-version": "cli-output-v1",
