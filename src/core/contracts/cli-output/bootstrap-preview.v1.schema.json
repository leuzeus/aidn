  "properties": {
    "contract_version": { "type": "string" },
    "command": { "type": "string" },
    "effect_class": { "type": "string" },
    "ok": { "type": "boolean" },
    "ts": { "type": "string" },
    "target_root": { "type": "string" },
    "mode": { "type": "string" },
    "mode_source": { "type": "string" },
    "profile": { "type": "string" },
    "pack": { "type": "string" },
    "dry_run": { "type": "boolean" },
    "wizard": { "type": "boolean" },
    "verify_requested": { "type": "boolean" },
    "operations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "errors": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
