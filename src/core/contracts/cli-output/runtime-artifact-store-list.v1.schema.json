{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aidn://contracts/cli-output/runtime-artifact-store-list.v1",
  "title": "aidn runtime artifact-store list --json",
  "type": "object",
  "x-aidn-command": "aidn runtime artifact-store list --json",
  "x-aidn-contract-version": "cli-output-v1",
  "required": [
    "action",
    "sqlite_file",
    "artifacts",
    "artifact_store_diagnostic"
  ],
  "properties": {
    "action": { "type": "string" },
    "sqlite_file": { "type": "string" },
    "artifacts": { "type": "array" },
    "artifact_store_diagnostic": {
      "type": "object",
      "required": ["scope", "action", "artifact_count", "path", "dry_run", "summary", "recommended_action"],
      "properties": {
        "scope": { "type": "string" },
        "action": { "type": "string" },
        "artifact_count": { "type": "number" },
        "path": { "type": "string" },
        "dry_run": { "type": "boolean" },
        "summary": { "type": "string" },
        "recommended_action": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
