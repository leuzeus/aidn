{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aidn://contracts/cli-output/runtime-shared-coordination-restore.v1",
  "title": "aidn runtime shared-coordination-restore --json",
  "type": "object",
  "x-aidn-command": "aidn runtime shared-coordination-restore --json",
  "x-aidn-contract-version": "cli-output-v1",
  "required": [
    "target_root",
    "input_file",
    "ok",
    "status",
    "reason",
    "write_requested",
    "workspace",
    "source_of_truth",
    "metadata",
    "shared_coordination_backend",
    "preview",
    "restore",
    "operations"
  ],
  "properties": {
    "target_root": { "type": "string" },
    "input_file": { "type": "string" },
    "ok": { "type": "boolean" },
    "status": { "type": "string" },
    "reason": { "type": "string" },
    "write_requested": { "type": "boolean" },
    "workspace": { "type": "object", "additionalProperties": true },
    "source_of_truth": { "type": "object", "additionalProperties": true },
    "metadata": { "type": "object", "additionalProperties": true },
    "shared_coordination_backend": { "type": "object", "additionalProperties": true },
    "health": { "type": ["object", "null"], "additionalProperties": true },
    "preview": {
