  "properties": {
    "target_root": { "type": "string" },
    "packet_file": { "type": "string" },
    "admission_status": { "type": "string" },
    "admitted": { "type": "boolean" },
    "recommended_action": { "type": "string" },
    "recommended_next_agent_role": { "type": "string" },
    "next_agent_goal": { "type": "string" },
    "route": { "type": "object", "additionalProperties": true },
    "status": { "type": "object", "additionalProperties": true },
    "workspace": { "type": "object", "additionalProperties": true },
    "shared_state_backend": { "type": ["object", "null"], "additionalProperties": true },
    "shared_runtime_validation": { "type": "object", "additionalProperties": true },
    "packet": { "type": "object", "additionalProperties": true },
    "transition_policy": { "type": "object", "additionalProperties": true },
    "prioritized_artifacts": { "type": "array" },
    "consistency": { "type": "object", "additionalProperties": true },
    "issues": { "type": "array" },
    "warnings": { "type": "array" }
