{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aidn://contracts/cli-output/runtime-handoff-admit.v1",
  "title": "aidn runtime handoff-admit --json",
  "type": "object",
  "x-aidn-command": "aidn runtime handoff-admit --json",
  "x-aidn-contract-version": "cli-output-v1",
  "required": [
