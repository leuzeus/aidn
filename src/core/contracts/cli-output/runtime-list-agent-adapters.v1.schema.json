        "state_mode",
        "roster_found",
        "adapter_count",
        "unavailable_adapter_count",
        "preview_error_count",
        "summary",
        "recommended_action"
      ],
      "properties": {
        "scope": { "type": "string" },
        "state_mode": { "type": "string" },
        "roster_found": { "type": "boolean" },
        "adapter_count": { "type": "number" },
        "unavailable_adapter_count": { "type": "number" },
        "preview_error_count": { "type": "number" },
        "summary": { "type": "string" },
        "recommended_action": { "type": "string" }
