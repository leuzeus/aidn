{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aidn://contracts/cli-output/runtime-project-agent-selection-summary.v1",
  "title": "aidn runtime project-agent-selection-summary --json",
  "type": "object",
  "x-aidn-command": "aidn runtime project-agent-selection-summary --json",
  "x-aidn-contract-version": "cli-output-v1",
  "required": [
    "target_root",
    "out_file",
    "written",
    "state_mode",
    "db_first_applied",
    "db_first_materialized",
    "db_first_artifact_path",
    "summary",
    "roster_verification",
    "agent_selection_diagnostic"
  ],
  "properties": {
    "target_root": { "type": "string" },
    "out_file": { "type": "string" },
    "written": { "type": "boolean" },
    "state_mode": { "type": "string" },
    "db_first_applied": { "type": "boolean" },
    "db_first_materialized": { "type": "boolean" },
    "db_first_artifact_path": { "type": "string" },
    "governance_metadata": {
      "type": "object",
      "required": [
        "contract_version",
        "source_of_truth",
        "source_mode",
        "lifecycle_status",
        "owner",
        "steward"
      ],
      "properties": {
        "contract_version": { "type": "string" },
        "source_of_truth": { "type": "string" },
        "source_mode": { "type": "string" },
        "lifecycle_status": { "type": "string" },
        "owner": { "type": "string" },
        "steward": { "type": "string" }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": ["adapters", "auto_selection_preview"],
      "properties": {
        "adapters": { "type": "array" },
        "auto_selection_preview": { "type": "array" }
      },
      "additionalProperties": true
    },
    "roster_verification": {
      "type": "object",
      "required": ["pass", "issues", "warnings"],
      "properties": {
        "pass": { "type": "boolean" },
        "issues": { "type": "array" },
        "warnings": { "type": "array" }
      },
      "additionalProperties": true
    },
    "agent_selection_diagnostic": {
      "type": "object",
      "required": [
        "scope",
        "state_mode",
        "roster_pass",
        "adapter_count",
        "preview_count",
        "written",
        "summary",
        "recommended_command"
      ],
      "properties": {
        "scope": { "type": "string" },
        "state_mode": { "type": "string" },
        "roster_pass": { "type": "boolean" },
        "adapter_count": { "type": "number" },
        "preview_count": { "type": "number" },
        "written": { "type": "boolean" },
        "summary": { "type": "string" },
        "recommended_command": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
