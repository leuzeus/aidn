        "recommended_action",
        "source",
        "stop_required",
        "scope_type",
        "scope_id",
        "summary",
        "recommended_command"
      ],
      "properties": {
        "scope": { "type": "string" },
        "recommended_role": { "type": "string" },
        "recommended_action": { "type": "string" },
        "source": { "type": "string" },
        "stop_required": { "type": "boolean" },
        "scope_type": { "type": "string" },
        "scope_id": { "type": "string" },
        "summary": { "type": "string" },
        "recommended_command": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
