        "backend_source",
        "backup_created",
        "compatibility_fallback_used",
        "summary",
        "recommended_action"
      ],
      "properties": {
        "scope": { "type": "string" },
        "backend": { "type": "string" },
        "backend_source": { "type": "string" },
        "backup_created": { "type": "boolean" },
        "compatibility_fallback_used": { "type": "boolean" },
        "summary": { "type": "string" },
        "recommended_action": { "type": "string" }
      },
      "additionalProperties": true
