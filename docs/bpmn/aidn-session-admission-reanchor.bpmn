<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_AidnSessionAdmissionReanchor"
  targetNamespace="https://github.com/leuzeus/aidn/bpmn"
  exporter="bpmn-js (https://demo.bpmn.io)"
  exporterVersion="18.13.1">
  <bpmn:process id="Process_AidnSessionAdmissionReanchor" name="aid'n session admission and re-anchor" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Admission">
      <bpmn:lane id="Lane_Admission_User" name="User / Operator">
        <bpmn:flowNodeRef>StartEvent_AdmissionRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AdmissionClarifyMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdmissionClarify</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Admission_Coordinator" name="Coordinator Agent">
        <bpmn:flowNodeRef>Gateway_AdmissionEntryMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AdmissionUserReady</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdmissionReanchor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AdmissionContextComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdmissionAssign</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdmissionPlanOnly</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_AdmissionPlanOnly</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Admission_Execution" name="Execution Agent">
        <bpmn:flowNodeRef>Task_AdmissionLoadCycleContext</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Admission_Audit" name="Audit Agent">
        <bpmn:flowNodeRef>Task_AdmissionCheckBranchCycle</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AdmissionCheckPreWrite</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AdmissionDorReady</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Admission_Runtime" name="Runtime / Repair Layer">
        <bpmn:flowNodeRef>EndEvent_AdmissionReady</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_AdmissionRequest" name="Receive request" />
    <bpmn:task id="Task_AdmissionClarify" name="Clarify scope" />
    <bpmn:exclusiveGateway id="Gateway_AdmissionClarifyMerge" name="Clarification path" />
    <bpmn:exclusiveGateway id="Gateway_AdmissionEntryMerge" name="Resume admission" />
    <bpmn:exclusiveGateway id="Gateway_AdmissionUserReady" name="User context ready?" default="Flow_AdmissionClarifyLoop" />
    <bpmn:task id="Task_AdmissionReanchor" name="Reload runtime context" />
    <bpmn:exclusiveGateway id="Gateway_AdmissionContextComplete" name="Context complete?" default="Flow_AdmissionClarifyBack" />
    <bpmn:task id="Task_AdmissionAssign" name="Admit session and assign work" />
    <bpmn:task id="Task_AdmissionLoadCycleContext" name="Load session and cycle context" />
    <bpmn:task id="Task_AdmissionCheckBranchCycle" name="Validate branch-cycle mapping" />
    <bpmn:task id="Task_AdmissionCheckPreWrite" name="Validate write prerequisites" />
    <bpmn:exclusiveGateway id="Gateway_AdmissionDorReady" name="Ready to write?" default="Flow_AdmissionPlanOnly" />
    <bpmn:task id="Task_AdmissionPlanOnly" name="Update plan in read-only mode" />
    <bpmn:endEvent id="EndEvent_AdmissionPlanOnly" name="Plan-only relay ready" />
    <bpmn:endEvent id="EndEvent_AdmissionReady" name="Execution admitted" />
    <bpmn:dataObjectReference id="Data_AdmissionCurrentState" name="CURRENT-STATE.md" dataObjectRef="DataObject_AdmissionCurrentState" />
    <bpmn:dataObject id="DataObject_AdmissionCurrentState" />
    <bpmn:dataObjectReference id="Data_AdmissionRuntimeState" name="RUNTIME-STATE.md" dataObjectRef="DataObject_AdmissionRuntimeState" />
    <bpmn:dataObject id="DataObject_AdmissionRuntimeState" />
    <bpmn:dataObjectReference id="Data_AdmissionCycleStatus" name="active cycle status.md" dataObjectRef="DataObject_AdmissionCycleStatus" />
    <bpmn:dataObject id="DataObject_AdmissionCycleStatus" />
    <bpmn:sequenceFlow id="Flow_AdmissionStart" sourceRef="StartEvent_AdmissionRequest" targetRef="Gateway_AdmissionEntryMerge" />
    <bpmn:sequenceFlow id="Flow_AdmissionResume" sourceRef="Gateway_AdmissionEntryMerge" targetRef="Gateway_AdmissionUserReady" />
    <bpmn:sequenceFlow id="Flow_AdmissionClarifyLoop" sourceRef="Gateway_AdmissionUserReady" targetRef="Gateway_AdmissionClarifyMerge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression"><![CDATA[need_clarification]]></bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AdmissionClarify" sourceRef="Gateway_AdmissionClarifyMerge" targetRef="Task_AdmissionClarify" />
    <bpmn:sequenceFlow id="Flow_AdmissionClarified" sourceRef="Task_AdmissionClarify" targetRef="Gateway_AdmissionEntryMerge" />
    <bpmn:sequenceFlow id="Flow_AdmissionReanchor" sourceRef="Gateway_AdmissionUserReady" targetRef="Task_AdmissionReanchor">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression"><![CDATA[clarified]]></bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AdmissionContextLoaded" sourceRef="Task_AdmissionReanchor" targetRef="Gateway_AdmissionContextComplete" />
    <bpmn:sequenceFlow id="Flow_AdmissionClarifyBack" sourceRef="Gateway_AdmissionContextComplete" targetRef="Gateway_AdmissionClarifyMerge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression"><![CDATA[context_incomplete]]></bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AdmissionAssignWork" sourceRef="Gateway_AdmissionContextComplete" targetRef="Task_AdmissionAssign">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression"><![CDATA[context_complete]]></bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AdmissionLoadContext" sourceRef="Task_AdmissionAssign" targetRef="Task_AdmissionLoadCycleContext" />
    <bpmn:sequenceFlow id="Flow_AdmissionCheckBranchCycle" sourceRef="Task_AdmissionLoadCycleContext" targetRef="Task_AdmissionCheckBranchCycle" />
    <bpmn:sequenceFlow id="Flow_AdmissionCheckPreWrite" sourceRef="Task_AdmissionCheckBranchCycle" targetRef="Task_AdmissionCheckPreWrite" />
    <bpmn:sequenceFlow id="Flow_AdmissionDorGate" sourceRef="Task_AdmissionCheckPreWrite" targetRef="Gateway_AdmissionDorReady" />
    <bpmn:sequenceFlow id="Flow_AdmissionPlanOnly" sourceRef="Gateway_AdmissionDorReady" targetRef="Task_AdmissionPlanOnly">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression"><![CDATA[dor_not_ready]]></bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AdmissionPlanOnlyEnd" sourceRef="Task_AdmissionPlanOnly" targetRef="EndEvent_AdmissionPlanOnly" />
    <bpmn:sequenceFlow id="Flow_AdmissionReady" sourceRef="Gateway_AdmissionDorReady" targetRef="EndEvent_AdmissionReady">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression"><![CDATA[dor_ready]]></bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:association id="Assoc_AdmissionCurrentState" sourceRef="Task_AdmissionReanchor" targetRef="Data_AdmissionCurrentState" />
    <bpmn:association id="Assoc_AdmissionRuntimeState" sourceRef="Task_AdmissionReanchor" targetRef="Data_AdmissionRuntimeState" />
    <bpmn:association id="Assoc_AdmissionCycleStatus" sourceRef="Task_AdmissionLoadCycleContext" targetRef="Data_AdmissionCycleStatus" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AidnSessionAdmissionReanchor">
    <bpmndi:BPMNPlane id="BPMNPlane_AidnSessionAdmissionReanchor" bpmnElement="Process_AidnSessionAdmissionReanchor">
      <bpmndi:BPMNShape id="Lane_Admission_User_di" bpmnElement="Lane_Admission_User" isHorizontal="true"><dc:Bounds x="100" y="80" width="2580" height="120" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Admission_Coordinator_di" bpmnElement="Lane_Admission_Coordinator" isHorizontal="true"><dc:Bounds x="100" y="200" width="2580" height="150" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Admission_Execution_di" bpmnElement="Lane_Admission_Execution" isHorizontal="true"><dc:Bounds x="100" y="350" width="2580" height="120" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Admission_Audit_di" bpmnElement="Lane_Admission_Audit" isHorizontal="true"><dc:Bounds x="100" y="470" width="2580" height="140" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Admission_Runtime_di" bpmnElement="Lane_Admission_Runtime" isHorizontal="true"><dc:Bounds x="100" y="610" width="2580" height="100" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_AdmissionRequest_di" bpmnElement="StartEvent_AdmissionRequest"><dc:Bounds x="170" y="122" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AdmissionClarifyMerge_di" bpmnElement="Gateway_AdmissionClarifyMerge" isMarkerVisible="true"><dc:Bounds x="470" y="115" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdmissionClarify_di" bpmnElement="Task_AdmissionClarify"><dc:Bounds x="620" y="100" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AdmissionEntryMerge_di" bpmnElement="Gateway_AdmissionEntryMerge" isMarkerVisible="true"><dc:Bounds x="300" y="250" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AdmissionUserReady_di" bpmnElement="Gateway_AdmissionUserReady" isMarkerVisible="true"><dc:Bounds x="470" y="250" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdmissionReanchor_di" bpmnElement="Task_AdmissionReanchor"><dc:Bounds x="620" y="235" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AdmissionContextComplete_di" bpmnElement="Gateway_AdmissionContextComplete" isMarkerVisible="true"><dc:Bounds x="900" y="250" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdmissionAssign_di" bpmnElement="Task_AdmissionAssign"><dc:Bounds x="1080" y="235" width="220" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdmissionLoadCycleContext_di" bpmnElement="Task_AdmissionLoadCycleContext"><dc:Bounds x="1420" y="370" width="190" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdmissionCheckBranchCycle_di" bpmnElement="Task_AdmissionCheckBranchCycle"><dc:Bounds x="1750" y="500" width="190" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdmissionCheckPreWrite_di" bpmnElement="Task_AdmissionCheckPreWrite"><dc:Bounds x="2050" y="500" width="190" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AdmissionDorReady_di" bpmnElement="Gateway_AdmissionDorReady" isMarkerVisible="true"><dc:Bounds x="2360" y="515" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdmissionPlanOnly_di" bpmnElement="Task_AdmissionPlanOnly"><dc:Bounds x="2300" y="235" width="200" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_AdmissionPlanOnly_di" bpmnElement="EndEvent_AdmissionPlanOnly"><dc:Bounds x="2520" y="257" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_AdmissionReady_di" bpmnElement="EndEvent_AdmissionReady"><dc:Bounds x="2520" y="642" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Data_AdmissionCurrentState_di" bpmnElement="Data_AdmissionCurrentState"><dc:Bounds x="520" y="20" width="36" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Data_AdmissionRuntimeState_di" bpmnElement="Data_AdmissionRuntimeState"><dc:Bounds x="590" y="20" width="36" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Data_AdmissionCycleStatus_di" bpmnElement="Data_AdmissionCycleStatus"><dc:Bounds x="1500" y="640" width="36" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_AdmissionStart_di" bpmnElement="Flow_AdmissionStart"><di:waypoint x="206" y="140" /><di:waypoint x="325" y="140" /><di:waypoint x="325" y="250" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionResume_di" bpmnElement="Flow_AdmissionResume"><di:waypoint x="350" y="275" /><di:waypoint x="470" y="275" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionClarifyLoop_di" bpmnElement="Flow_AdmissionClarifyLoop"><di:waypoint x="495" y="250" /><di:waypoint x="495" y="165" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionClarify_di" bpmnElement="Flow_AdmissionClarify"><di:waypoint x="520" y="140" /><di:waypoint x="620" y="140" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionClarified_di" bpmnElement="Flow_AdmissionClarified"><di:waypoint x="710" y="180" /><di:waypoint x="710" y="275" /><di:waypoint x="350" y="275" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionReanchor_di" bpmnElement="Flow_AdmissionReanchor"><di:waypoint x="520" y="275" /><di:waypoint x="620" y="275" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionContextLoaded_di" bpmnElement="Flow_AdmissionContextLoaded"><di:waypoint x="800" y="275" /><di:waypoint x="900" y="275" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionClarifyBack_di" bpmnElement="Flow_AdmissionClarifyBack"><di:waypoint x="925" y="250" /><di:waypoint x="925" y="140" /><di:waypoint x="520" y="140" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionAssignWork_di" bpmnElement="Flow_AdmissionAssignWork"><di:waypoint x="950" y="275" /><di:waypoint x="1080" y="275" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionLoadContext_di" bpmnElement="Flow_AdmissionLoadContext"><di:waypoint x="1300" y="275" /><di:waypoint x="1515" y="275" /><di:waypoint x="1515" y="370" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionCheckBranchCycle_di" bpmnElement="Flow_AdmissionCheckBranchCycle"><di:waypoint x="1610" y="410" /><di:waypoint x="1845" y="410" /><di:waypoint x="1845" y="500" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionCheckPreWrite_di" bpmnElement="Flow_AdmissionCheckPreWrite"><di:waypoint x="1940" y="540" /><di:waypoint x="2050" y="540" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionDorGate_di" bpmnElement="Flow_AdmissionDorGate"><di:waypoint x="2240" y="540" /><di:waypoint x="2360" y="540" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionPlanOnly_di" bpmnElement="Flow_AdmissionPlanOnly"><di:waypoint x="2385" y="515" /><di:waypoint x="2385" y="275" /><di:waypoint x="2300" y="275" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionPlanOnlyEnd_di" bpmnElement="Flow_AdmissionPlanOnlyEnd"><di:waypoint x="2500" y="275" /><di:waypoint x="2520" y="275" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmissionReady_di" bpmnElement="Flow_AdmissionReady"><di:waypoint x="2385" y="565" /><di:waypoint x="2385" y="660" /><di:waypoint x="2520" y="660" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Assoc_AdmissionCurrentState_di" bpmnElement="Assoc_AdmissionCurrentState"><di:waypoint x="538" y="70" /><di:waypoint x="538" y="235" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Assoc_AdmissionRuntimeState_di" bpmnElement="Assoc_AdmissionRuntimeState"><di:waypoint x="608" y="70" /><di:waypoint x="608" y="235" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Assoc_AdmissionCycleStatus_di" bpmnElement="Assoc_AdmissionCycleStatus"><di:waypoint x="1518" y="640" /><di:waypoint x="1518" y="450" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
