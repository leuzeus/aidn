<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_AidnMultiAgentIdeal" targetNamespace="https://github.com/leuzeus/aidn/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1">
  <bpmn:process id="Process_AidnMultiAgentIdeal" name="aid&#39;n multi-agent workflow (current runtime baseline)" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Main">
      <bpmn:lane id="Lane_Runtime" name="Runtime / Repair Layer">
        <bpmn:flowNodeRef>Task_HydrateRuntime</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RepairBlocked</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RepairStatus</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TriageRepair</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Audit" name="Audit Agent">
        <bpmn:flowNodeRef>Task_CheckBranchAndCycle</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckPreWriteGate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DorReady</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DriftReviewMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DriftAndTraceabilityReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_HandoffNeeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_CloseSession</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CloseArtifacts</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Execution" name="Execution Agent">
        <bpmn:flowNodeRef>Task_LoadCycleContext</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ImplementMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ImplementChange</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Coordinator" name="Coordinator Agent">
        <bpmn:flowNodeRef>Gateway_ReanchorUserMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ReanchorLoopMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ReanchorMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReanchorContext</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ContextComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AssignWork</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PreparePlanOnly</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ProjectHandoffPacket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_HandoffComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PublishSessionState</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SessionPublished</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_User" name="User / Operator">
        <bpmn:flowNodeRef>StartEvent_Request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ClarifyIntent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArbitrateBlock</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Request" name="Receive request" />
    <bpmn:exclusiveGateway id="Gateway_ReanchorUserMerge" name="Resume after clarification" />
    <bpmn:exclusiveGateway id="Gateway_ReanchorLoopMerge" name="Resume loop" />
    <bpmn:exclusiveGateway id="Gateway_ReanchorMerge" name="Reload workflow path" />
    <bpmn:task id="Task_ReanchorContext" name="Reload runtime context" />
    <bpmn:exclusiveGateway id="Gateway_ContextComplete" name="Context complete?" default="Flow_ContextNo" />
    <bpmn:task id="Task_ClarifyIntent" name="Clarify scope" />
    <bpmn:task id="Task_AssignWork" name="Admit session and assign work" />
    <bpmn:task id="Task_LoadCycleContext" name="Load session and cycle context" />
    <bpmn:task id="Task_CheckBranchAndCycle" name="Validate branch-cycle mapping" />
    <bpmn:task id="Task_CheckPreWriteGate" name="Validate write prerequisites" />
    <bpmn:exclusiveGateway id="Gateway_DorReady" name="Ready to write?" default="Flow_DorNo" />
    <bpmn:task id="Task_PreparePlanOnly" name="Update plan in read-only mode" />
    <bpmn:exclusiveGateway id="Gateway_ImplementMerge" name="Writing path" />
    <bpmn:task id="Task_ImplementChange" name="Implement planned change" />
    <bpmn:task id="Task_HydrateRuntime" name="Refresh runtime state" />
    <bpmn:exclusiveGateway id="Gateway_RepairBlocked" name="Repair blocked?" default="Flow_RepairNotBlocked" />
    <bpmn:exclusiveGateway id="Gateway_RepairStatus" name="Repair warning?" default="Flow_RepairWarn" />
    <bpmn:task id="Task_TriageRepair" name="Run repair triage" />
    <bpmn:task id="Task_ArbitrateBlock" name="Arbitrate blocking issue" />
    <bpmn:exclusiveGateway id="Gateway_DriftReviewMerge" name="Review path" />
    <bpmn:task id="Task_DriftAndTraceabilityReview" name="Review drift and traceability" />
    <bpmn:exclusiveGateway id="Gateway_HandoffNeeded" name="Need another agent?" default="Flow_HandoffNo" />
    <bpmn:task id="Task_ProjectHandoffPacket" name="Prepare handoff packet" />
    <bpmn:exclusiveGateway id="Gateway_CloseSession" name="Close session now?" default="Flow_CloseNo" />
    <bpmn:task id="Task_CloseArtifacts" name="Close session and orchestrate PR" />
    <bpmn:task id="Task_PublishSessionState" name="Publish session state" />
    <bpmn:endEvent id="EndEvent_HandoffComplete" name="Handoff prepared" />
    <bpmn:endEvent id="EndEvent_SessionPublished" name="Session state published" />
    <bpmn:dataObjectReference id="Data_CurrentState" name="CURRENT-STATE.md" dataObjectRef="DataObject_CurrentState" />
    <bpmn:dataObject id="DataObject_CurrentState" />
    <bpmn:dataObjectReference id="Data_CurrentState_Publish" name="CURRENT-STATE.md" dataObjectRef="DataObject_CurrentState" />
    <bpmn:dataObjectReference id="Data_RuntimeState" name="RUNTIME-STATE.md" dataObjectRef="DataObject_RuntimeState" />
    <bpmn:dataObject id="DataObject_RuntimeState" />
    <bpmn:dataObjectReference id="Data_RuntimeState_Reanchor" name="RUNTIME-STATE.md" dataObjectRef="DataObject_RuntimeState" />
    <bpmn:dataObjectReference id="Data_HandoffPacket" name="HANDOFF-PACKET.md" dataObjectRef="DataObject_HandoffPacket" />
    <bpmn:dataObject id="DataObject_HandoffPacket" />
    <bpmn:dataObjectReference id="Data_HandoffPacket_Reanchor" name="HANDOFF-PACKET.md" dataObjectRef="DataObject_HandoffPacket" />
    <bpmn:dataObjectReference id="Data_CycleStatus" name="active cycle status.md" dataObjectRef="DataObject_CycleStatus" />
    <bpmn:dataObject id="DataObject_CycleStatus" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_Request" targetRef="Gateway_ReanchorUserMerge" />
    <bpmn:sequenceFlow id="Flow_ReanchorUserToMain" sourceRef="Gateway_ReanchorUserMerge" targetRef="Gateway_ReanchorMerge" />
    <bpmn:sequenceFlow id="Flow_ReanchorLoopToMain" sourceRef="Gateway_ReanchorLoopMerge" targetRef="Gateway_ReanchorMerge" />
    <bpmn:sequenceFlow id="Flow_ReanchorGo" sourceRef="Gateway_ReanchorMerge" targetRef="Task_ReanchorContext" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ReanchorContext" targetRef="Gateway_ContextComplete" />
    <bpmn:sequenceFlow id="Flow_ContextNo" sourceRef="Gateway_ContextComplete" targetRef="Task_ClarifyIntent">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">context_incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ContextYes" sourceRef="Gateway_ContextComplete" targetRef="Task_AssignWork">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">context_complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ClarifyBack" sourceRef="Task_ClarifyIntent" targetRef="Gateway_ReanchorUserMerge" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_AssignWork" targetRef="Task_LoadCycleContext" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_LoadCycleContext" targetRef="Task_CheckBranchAndCycle" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_CheckBranchAndCycle" targetRef="Task_CheckPreWriteGate" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_CheckPreWriteGate" targetRef="Gateway_DorReady" />
    <bpmn:sequenceFlow id="Flow_DorNo" sourceRef="Gateway_DorReady" targetRef="Task_PreparePlanOnly">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">dor_not_ready</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_DorYes" sourceRef="Gateway_DorReady" targetRef="Gateway_ImplementMerge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">dor_ready</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_PlanLoop" sourceRef="Task_PreparePlanOnly" targetRef="Gateway_ReanchorLoopMerge" />
    <bpmn:sequenceFlow id="Flow_ImplementGo" sourceRef="Gateway_ImplementMerge" targetRef="Task_ImplementChange" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_ImplementChange" targetRef="Task_HydrateRuntime" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_HydrateRuntime" targetRef="Gateway_RepairBlocked" />
    <bpmn:sequenceFlow id="Flow_RepairNotBlocked" sourceRef="Gateway_RepairBlocked" targetRef="Gateway_RepairStatus">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">ok_or_warn</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RepairOk" sourceRef="Gateway_RepairStatus" targetRef="Gateway_DriftReviewMerge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">repair_ok</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RepairWarn" sourceRef="Gateway_RepairStatus" targetRef="Task_TriageRepair">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">repair_warn</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RepairBlock" sourceRef="Gateway_RepairBlocked" targetRef="Task_ArbitrateBlock">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">repair_block</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_TriageBack" sourceRef="Task_TriageRepair" targetRef="Gateway_DriftReviewMerge" />
    <bpmn:sequenceFlow id="Flow_DriftReviewGo" sourceRef="Gateway_DriftReviewMerge" targetRef="Task_DriftAndTraceabilityReview" />
    <bpmn:sequenceFlow id="Flow_BlockBack" sourceRef="Task_ArbitrateBlock" targetRef="Gateway_ReanchorLoopMerge" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_DriftAndTraceabilityReview" targetRef="Gateway_HandoffNeeded" />
    <bpmn:sequenceFlow id="Flow_HandoffYes" sourceRef="Gateway_HandoffNeeded" targetRef="Task_ProjectHandoffPacket">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">handoff_needed</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_HandoffNo" sourceRef="Gateway_HandoffNeeded" targetRef="Gateway_CloseSession">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">continue_same_agent</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_HandoffLoop" sourceRef="Task_ProjectHandoffPacket" targetRef="EndEvent_HandoffComplete" />
    <bpmn:sequenceFlow id="Flow_CloseYes" sourceRef="Gateway_CloseSession" targetRef="Task_CloseArtifacts">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">close_now</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_CloseNo" sourceRef="Gateway_CloseSession" targetRef="Gateway_ImplementMerge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">continue_working</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_CloseArtifacts" targetRef="Task_PublishSessionState" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_PublishSessionState" targetRef="EndEvent_SessionPublished" />
    <bpmn:association id="Assoc_1" sourceRef="Task_ReanchorContext" targetRef="Data_CurrentState" />
    <bpmn:association id="Assoc_2" sourceRef="Task_ReanchorContext" targetRef="Data_RuntimeState_Reanchor" />
    <bpmn:association id="Assoc_3" sourceRef="Task_ReanchorContext" targetRef="Data_HandoffPacket_Reanchor" />
    <bpmn:association id="Assoc_4" sourceRef="Task_LoadCycleContext" targetRef="Data_CycleStatus" />
    <bpmn:association id="Assoc_5" sourceRef="Task_HydrateRuntime" targetRef="Data_RuntimeState" />
    <bpmn:association id="Assoc_6" sourceRef="Task_ProjectHandoffPacket" targetRef="Data_HandoffPacket" />
    <bpmn:association id="Assoc_7" sourceRef="Task_PublishSessionState" targetRef="Data_CurrentState_Publish" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AidnMultiAgentIdeal">
    <bpmndi:BPMNPlane id="BPMNPlane_AidnMultiAgentIdeal" bpmnElement="Process_AidnMultiAgentIdeal">
