{
  "name": "aidn-workflow",
  "description": "aid’n — Audit-driven, session-based workflow packaging system for structured AI-assisted development",
  "private": true,
  "type": "module",
  "scripts": {
    "install-pack": "node tools/install.mjs",
    "build-release": "node tools/build-release.mjs",
    "perf:collect": "node tools/perf/collect-event.mjs",
    "perf:report": "node tools/perf/report-kpi.mjs",
    "perf:index": "node tools/perf/index-sync.mjs",
    "perf:reload-check": "node tools/perf/reload-check.mjs",
    "perf:gate": "node tools/perf/gating-evaluate.mjs",
    "perf:checkpoint": "node tools/perf/checkpoint.mjs",
    "perf:check-thresholds": "node tools/perf/check-thresholds.mjs",
    "perf:render-summary": "node tools/perf/render-summary.mjs",
    "perf:hook": "node tools/perf/workflow-hook.mjs",
    "perf:session-start": "node tools/perf/workflow-hook.mjs --phase session-start",
    "perf:session-close": "node tools/perf/workflow-hook.mjs --phase session-close",
    "perf:delivery-start": "node tools/perf/delivery-window.mjs --action start",
    "perf:delivery-end": "node tools/perf/delivery-window.mjs --action end"
  }
}
